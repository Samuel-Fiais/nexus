{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=nexus.db"
  },
  "App": {
    "Timezone": "America/Sao_Paulo",
    "LlmTimeoutSeconds": 60
  },
  "Llm": {
    "Provider": "deepseek"
  },
  "DeepSeek": {
    "BaseUrl": "https://api.deepseek.com",
    "Model": "deepseek-chat"
    // ApiKey NAO deve ser definida aqui. Configure via variavel de ambiente
    // DeepSeek__ApiKey ou via user-secrets em ambiente de desenvolvimento.
  },
  "Tavily": {
    "BaseUrl": "https://api.tavily.com"
    // ApiKey NAO deve ser definida aqui. Configure via variavel de ambiente
    // Tavily__ApiKey ou via user-secrets em ambiente de desenvolvimento.
  },
  "Slack": {
    // SigningSecret e BotToken vem de variaveis de ambiente (Slack__SigningSecret, Slack__BotToken)
    // ou user-secrets. Nunca comitar valores reais aqui.
    // AllowedTeamId (Slack__AllowedTeamId): quando definido, somente eventos desse workspace
    // sao processados (regra 9.1). Obrigatorio antes de expor o bot fora de ambiente controlado.
  },
  "Admin": {
    // ApiKey (Admin__ApiKey): chave exigida no header X-Admin-Api-Key dos endpoints /admin/*.
    // Enquanto nao definida, os endpoints administrativos respondem 401.
  },
  "Knowledge": {
    "LocalFolderPath": "./knowledge"
  },
  "Sync": {
    "IntervalMinutes": 15
  },
  "Retention": {
    "UserDailyUsageDays": 90
  }
}
