{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=nexus.db"
  },
  "App": {
    "Timezone": "America/Sao_Paulo",
    "LlmTimeoutSeconds": 60
  },
  "Llm": {
    "Provider": "deepseek"
  },
  "DeepSeek": {
    "BaseUrl": "https://api.deepseek.com",
    "Model": "deepseek-chat"
    // ApiKey via env var DeepSeek__ApiKey ou user-secrets; usada tambem pelo auto-tagging
    // da ingestao. Nunca comitar valores reais aqui.
  },
  "Tavily": {
    "BaseUrl": "https://api.tavily.com"
    // ApiKey via env var Tavily__ApiKey ou user-secrets (extracao de website_link).
  },
  "Knowledge": {
    "LocalFolderPath": "./knowledge"
  },
  "Sync": {
    "IntervalMinutes": 15
  },
  "Retention": {
    "UserDailyUsageDays": 90
  }
}
